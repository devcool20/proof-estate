# PostgreSQL connection string
# Format: postgres://USER:PASSWORD@HOST:PORT/DATABASE
DATABASE_URL=postgres://postgres:password@localhost:5432/proofestate

# Solana cluster (localnet | devnet | mainnet-beta)
SOLANA_RPC_URL=https://api.devnet.solana.com

# Proof Estate Program ID (from Anchor.toml)
PROGRAM_ID=Fg6PaFpoGXkYsidMpWTK6W2BeZ7FEfcYkg476zPFsLnS

# Verifier authority wallet (admin private key base58 – keep secret!)
VERIFIER_SECRET_KEY=your_verifier_secret_key_here

# Backend listening port (avoid 8080 on Windows — often blocked by firewall)
PORT=3001
